<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>$homeLoc$</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
$for(pages)$
  <url>
    <loc>$loc$</loc>
    $if(lastmod)$<lastmod>$lastmod$</lastmod>$endif$
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
$endfor$
</urlset>